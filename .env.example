# Server
HOST=0.0.0.0
PORT=8000
WORKER_COUNT=2
KEEPALIVE_SECONDS=5

# Behavior
DEFAULT_STATUS_CODE=200
TIMEOUT_SECONDS=30
MAX_PAYLOAD_BYTES=1048576
ENABLE_DEBUG=false
ENABLE_GZIP=true

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=true

# Auth simulation
MOCK_AUTH_TOKEN=test-token-12345

# Rate limits (slowapi syntax)
RATE_LIMIT_GLOBAL=500/minute
RATE_LIMIT_PER_IP=100/minute
RATE_LIMIT_AUTH=20/minute

# Allowed headers (comma-separated)
ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,X-Scenario,X-Debug-Mode

# Scenarios config
SCENARIOS_FILE=app/engine/scenarios.yaml
SCENARIOS_HOT_RELOAD=true
